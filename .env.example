# Infrastructure
POSTGRES_USER=shopmicro
POSTGRES_PASSWORD=shopmicro_pass

# Per-service databases
USER_DB=user_db
PRODUCT_DB=product_db
ORDER_DB=order_db
INVENTORY_DB=inventory_db

# Redis
REDIS_URL=redis://redis:6379

# MongoDB
MONGO_URL=mongodb://mongo:27017
MONGO_DB=notification_db

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# Keycloak
KEYCLOAK_URL=http://keycloak:8080
KEYCLOAK_REALM=shopmicro
KEYCLOAK_CLIENT_ID=shopmicro-client
KEYCLOAK_CLIENT_SECRET=change_me_in_prod

# JWT
JWT_ALGORITHM=RS256

# Service URLs (for inter-service communication)
USER_SERVICE_URL=http://user-service:8001
PRODUCT_SERVICE_URL=http://product-service:8002
ORDER_SERVICE_URL=http://order-service:8003
INVENTORY_SERVICE_URL=http://inventory-service:8004

# OTEL
OTEL_EXPORTER_OTLP_ENDPOINT=http://jaeger:4317
OTEL_SERVICE_NAME=undefined  # overridden per service
